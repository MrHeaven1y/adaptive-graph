# Normalize line endings across OS
* text=auto eol=lf

# Force LF for web + WASM projects (important for you)
*.c   text eol=lf
*.h   text eol=lf
*.js  text eol=lf
*.html text eol=lf
*.css text eol=lf
*.json text eol=lf

# Binary files (don’t touch)
*.wasm binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary